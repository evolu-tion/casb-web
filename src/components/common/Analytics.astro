---
import { ANALYTICS } from '~/utils/config';

const id = ANALYTICS?.vendors?.googleAnalytics?.id;
---

{
  id && id.startsWith('GTM-') ? (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtm.js?id=${String(id)}`} />
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${String(id)}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        />
      </noscript>
    </>
  ) : id && id.startsWith('G-') ? (
    <>
      <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${String(id)}`} async />
      <script
        is:inline
        set:html={`window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', '${String(id)}');`}
      />
    </>
  ) : null
}
